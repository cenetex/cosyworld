{
  "schema_version": 1,
  "id": "cosyworld.the-holy-land",
  "name": "The Holy Land",
  "version": "1.1.0",
  "kind": "world",
  "description": "A watercolor pilgrimage through Gospel-associated places with the Twelve and generative wayside supplicants; Jesus is not depicted as an actor or collectible card.",
  "license": "MIT",
  "engine": ">=0.0.20 <0.1.0",
  "capabilities": [
    {
      "id": "cosyworld.the-holy-land/world",
      "kind": "world",
      "version": "1.0.0"
    },
    {
      "id": "cosyworld.the-holy-land/assets",
      "kind": "assets",
      "version": "1.0.0"
    }
  ],
  "dependencies": [
    {
      "id": "cosyworld.core",
      "version": ">=1.0.0 <2.0.0",
      "capabilities": [
        "cosyworld.core/world"
      ]
    }
  ],
  "default_ruleset": null,
  "entry_points": [
    {
      "kind": "location",
      "id": "location/700"
    },
    {
      "kind": "asset_mount",
      "id": "cards"
    }
  ],
  "provenance": {
    "source_name": "CosyWorld: The Holy Land",
    "source_url": "https://github.com/cenetex/cosyworld"
  },
  "resources": {
    "actors": "actors.json",
    "locations": "locations.json",
    "exits": "exits.json",
    "room_features": "room_features.json",
    "room_sheets": "room_sheets.json",
    "cards": "cards.json"
  },
  "assets": [
    {
      "provider": "cosyworld.the-holy-land/assets",
      "mount": "cards",
      "directory": "assets/cards",
      "public_prefix": "/assets/the-holy-land/cards",
      "optional": false
    }
  ]
}
