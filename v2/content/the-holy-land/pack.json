{
  "schema_version": 2,
  "id": "cosyworld.the-holy-land",
  "name": "The Holy Land",
  "version": "1.0.0",
  "kind": "world",
  "description": "A watercolor pilgrimage through Gospel-associated places with the Twelve and generative wayside supplicants; Jesus is not depicted as an actor or collectible card.",
  "license": "MIT",
  "engine": ">=0.0.20 <0.1.0",
  "dependencies": [
    "cosyworld.core"
  ],
  "resources": {
    "actors": "actors.json",
    "locations": "locations.json",
    "exits": "exits.json",
    "room_features": "room_features.json",
    "room_sheets": "room_sheets.json",
    "cards": "cards.json"
  },
  "assets": [
    {
      "mount": "cards",
      "directory": "assets/cards",
      "public_prefix": "/assets/the-holy-land/cards",
      "optional": false
    }
  ]
}
