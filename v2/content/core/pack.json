{
  "schema_version": 1,
  "id": "cosyworld.core",
  "name": "CosyWorld Core",
  "version": "1.3.3",
  "kind": "world",
  "description": "The first-party CosyWorld rooms, residents, items, cards, and world systems.",
  "license": "MIT",
  "license_url": "https://opensource.org/license/mit",
  "engine": ">=0.0.20 <0.1.0",
  "capabilities": [
    {
      "id": "cosyworld.core/world",
      "kind": "world",
      "version": "1.0.0"
    },
    {
      "id": "cosyworld.core/assets",
      "kind": "assets",
      "version": "1.0.0"
    },
    {
      "id": "cosyworld.core/rules",
      "kind": "rules",
      "version": "1.0.0"
    }
  ],
  "dependencies": [
    {
      "id": "cosyworld.rules-profile-srd5",
      "version": ">=1.0.0 <2.0.0",
      "capabilities": [
        "cosyworld.rules-profile-srd5/rules"
      ]
    }
  ],
  "default_ruleset": "cosyworld.core/rules",
  "rules_profile": "cosyworld.srd5/1",
  "entry_points": [
    {
      "kind": "location",
      "id": "location/1"
    }
  ],
  "provenance": {
    "author": "Cenetex",
    "source_name": "CosyWorld",
    "source_url": "https://github.com/cenetex/cosyworld"
  },
  "resources": {
    "actors": "actors.json",
    "factions": "factions.json",
    "items": "items.json",
    "locations": "locations.json",
    "exits": "exits.json",
    "hidden_exits": "hidden_exits.json",
    "room_features": "room_features.json",
    "room_sheets": "room_sheets.json",
    "clocks": "clocks.json",
    "jobs": "jobs.json",
    "action_vocabulary": "action_vocabulary.json",
    "fronts": "fronts.json",
    "cards": "cards.json",
    "lifecycle_hooks": "lifecycle_hooks.json",
    "evolution_tracks": "evolution_tracks.json",
    "recipes": "recipes.json",
    "sentences": "sentences.json"
  },
  "contributions": {
    "offers": "offers.json"
  },
  "assets": [
    {
      "provider": "cosyworld.core/assets",
      "mount": "generated/cards",
      "directory": "assets/generated/cards",
      "public_prefix": "/assets/generated/cards",
      "optional": false
    },
    {
      "provider": "cosyworld.core/assets",
      "mount": "locations",
      "directory": "assets/locations",
      "public_prefix": "/assets/locations",
      "optional": false
    }
  ]
}
