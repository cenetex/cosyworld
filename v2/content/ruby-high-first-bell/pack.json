{
  "schema_version": 1,
  "id": "ruby-high.first-bell",
  "name": "Ruby High: First Bell",
  "version": "1.3.1",
  "kind": "world",
  "description": "An independently bootable school world, card catalog, and entitlement-gated First Bell experience.",
  "license": "MIT",
  "license_url": "https://opensource.org/license/mit",
  "engine": ">=0.0.20 <0.1.0",
  "capabilities": [
    {
      "id": "ruby-high.first-bell/world",
      "kind": "world",
      "version": "1.0.0"
    },
    {
      "id": "ruby-high.first-bell/rules",
      "kind": "rules",
      "version": "1.0.0"
    },
    {
      "id": "ruby-high.first-bell/cards",
      "kind": "cards",
      "version": "1.0.0"
    },
    {
      "id": "ruby-high.first-bell/assets",
      "kind": "assets",
      "version": "1.0.0"
    },
    {
      "id": "ruby-high.first-bell/entitlements",
      "kind": "entitlements",
      "version": "1.0.0"
    }
  ],
  "dependencies": [
    {
      "id": "cosyworld.core",
      "version": ">=1.3.0 <2.0.0",
      "capabilities": [
        "cosyworld.core/world"
      ],
      "optional": true
    }
  ],
  "entry_points": [
    {
      "kind": "location",
      "id": "location/11"
    },
    {
      "kind": "card_catalog",
      "id": "first-bell"
    },
    {
      "kind": "asset_mount",
      "id": "cards"
    }
  ],
  "provenance": {
    "author": "Ruby High",
    "source_name": "Ruby High: First Bell",
    "source_url": "https://ruby-high.ai"
  },
  "distribution": {
    "media_type": "application/vnd.cosyworld.pack+json",
    "canonicalization": "jcs",
    "permanence": "content-addressed"
  },
  "entitlements": {
    "schema_version": 1,
    "authorities": [
      {
        "provider": "ruby-high.first-bell/entitlements",
        "id": "first-bell-card-feed",
        "type": "asset_feed",
        "asset_kind": "nft",
        "issuer": "ruby-high.ai",
        "chain": "solana",
        "network": "mainnet-beta",
        "standard": "metaplex_core",
        "collection_binding": "RUBY_HIGH_SOLANA_CORE_CARD_COLLECTION_ADDRESS"
      }
    ],
    "grants": [
      {
        "id": "ruby-high.first-bell:location-science-lab",
        "authority_id": "first-bell-card-feed",
        "match": {
          "asset_id": "location-science-lab"
        }
      },
      {
        "id": "ruby-high.first-bell:location-homeroom",
        "authority_id": "first-bell-card-feed",
        "match": {
          "asset_id": "location-homeroom"
        }
      },
      {
        "id": "ruby-high.first-bell:location-library",
        "authority_id": "first-bell-card-feed",
        "match": {
          "asset_id": "location-library"
        }
      },
      {
        "id": "ruby-high.first-bell:location-cafeteria",
        "authority_id": "first-bell-card-feed",
        "match": {
          "asset_id": "location-cafeteria"
        }
      },
      {
        "id": "ruby-high.first-bell:location-greenhouse",
        "authority_id": "first-bell-card-feed",
        "match": {
          "asset_id": "location-greenhouse"
        }
      },
      {
        "id": "ruby-high.first-bell:location-courtyard",
        "authority_id": "first-bell-card-feed",
        "match": {
          "asset_id": "location-courtyard"
        }
      }
    ]
  },
  "resources": {
    "actor_facets": "actor_facets.json",
    "access_gates": "access_gates.json",
    "factions": "factions.json",
    "locations": "locations.json",
    "exits": "exits.json",
    "room_features": "room_features.json",
    "room_sheets": "room_sheets.json",
    "cards": "cards.json",
    "card_bindings": "card_bindings.json",
    "sentences": "sentences.json"
  },
  "external_cards": "external_cards.json",
  "assets": [
    {
      "provider": "ruby-high.first-bell/assets",
      "mount": "cards",
      "directory": "assets/cards",
      "public_prefix": "/assets/cards",
      "optional": true,
      "fallback": "external_uri"
    }
  ],
  "default_ruleset": "ruby-high.first-bell/rules",
  "extensions": {
    "x-cosyworld-rules-context": {
      "vocabulary": {
        "actions": [
          "study",
          "test",
          "revise",
          "attend"
        ],
        "narration": [
          "first bell",
          "hall pass",
          "evidence",
          "homeroom"
        ]
      }
    }
  }
}
