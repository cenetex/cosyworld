{
  "name": "cosyworld",
  "version": "0.0.72",
  "description": "Shared AI MUD runtime with a deterministic C kernel and Rust orchestrator",
  "type": "module",
  "private": true,
  "main": "src/index.mjs",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "dev": "npm run v2:start",
    "dev:game": "npm run v2:start",
    "dev:node": "WEB_PORT=3001 cross-env NODE_ENV=development DEBUG=awilix:resolver nodemon src/index.mjs --delay 3000",
    "start": "cross-env NODE_ENV=production node src/index.mjs",
    "serve:prod": "npm run start",
    "check": "npm test && npm run v2:worldpack && npm run v2:kernel && npm run v2:rust:test && npm run v2:syntax",
    "check:local": "npm test && npm run v2:check",
    "v2:start": "./v2/mvp.sh start",
    "v2:restart": "./v2/mvp.sh restart",
    "v2:status": "./v2/mvp.sh status",
    "v2:smoke": "./v2/mvp.sh smoke",
    "v2:smoke:ruby-high-deploy": "node v2/scripts/smoke-deployed-ruby-high.mjs",
    "v2:check": "./v2/mvp.sh check",
    "v2:stop": "./v2/mvp.sh stop",
    "v2:worldpack": "npm run v2:worldpack:official && npm run v2:worldpack:compositions && npm run v2:proof-world -- --strict",
    "v2:worldpack:official": "node v2/scripts/import-srd-5.1.mjs --check && node v2/scripts/import-srd-5.2.1.mjs --check && node v2/scripts/compile-worldpack.mjs --check && node v2/scripts/check-worldpack.mjs",
    "v2:worldpack:compositions": "node v2/scripts/compile-worldpack.mjs --world-dir v2/worlds/core-only --output-dir v2/content/core-only --check && node v2/scripts/check-worldpack.mjs v2/content/core-only && node v2/scripts/compile-worldpack.mjs --world-dir v2/worlds/ruby-high-only --output-dir v2/content/ruby-high-only --check && node v2/scripts/check-worldpack.mjs v2/content/ruby-high-only && node v2/scripts/compile-worldpack.mjs --world-dir v2/worlds/services-only --output-dir v2/content/services-only --check && node v2/scripts/check-worldpack.mjs v2/content/services-only",
    "v2:worldpack:sync": "node v2/scripts/sync-worldpacks.mjs",
    "v2:worldpack:compile": "node v2/scripts/compile-worldpack.mjs",
    "v2:worldpack:lock": "node v2/scripts/compile-worldpack.mjs --write-lock",
    "v2:content-refs:migrate": "node v2/scripts/migrate-content-references.mjs",
    "v2:pack:unmount": "node v2/scripts/migrate-pack-unmount.mjs",
    "v2:srd:import": "node v2/scripts/import-srd-5.1.mjs && node v2/scripts/import-srd-5.2.1.mjs",
    "v2:srd:check": "node v2/scripts/import-srd-5.1.mjs --check && node v2/scripts/import-srd-5.2.1.mjs --check",
    "v2:holy-land:art": "node v2/scripts/generate-holy-land-art.mjs",
    "v2:kernel": "bash ./v2/scripts/check-kernel.sh",
    "v2:ai-model:test": "cargo test --manifest-path v2/ai-model-rust/Cargo.toml",
    "v2:ai-model:wasm": "cargo build --manifest-path v2/ai-model-rust/Cargo.toml --target wasm32-unknown-unknown --release",
    "v2:rust:test": "bash ./v2/scripts/check-rust.sh test",
    "v2:rust:build": "bash ./v2/scripts/check-rust.sh build",
    "v2:worldpack:inspect": "node v2/scripts/import-srd-5.1.mjs --check && node v2/scripts/import-srd-5.2.1.mjs --check && node v2/scripts/compile-worldpack.mjs --check && node v2/scripts/check-worldpack.mjs --report",
    "v2:proof-world": "node v2/scripts/check-proof-world.mjs",
    "v2:syntax": "node --check v2/scripts/smoke-browser.mjs && node --check v2/scripts/smoke-production-profile.mjs && node --check v2/scripts/smoke-deployed-ruby-high.mjs && python3 -m py_compile v2/cli/cosy_cli.py",
    "reset-setup": "node scripts/reset-setup.mjs",
    "build": "npm run clean && npm run build:js && npm run docs",
    "clean": "node -e \"require('fs').rmSync('dist', {recursive: true, force: true})\"",
    "build:js": "npx webpack --mode production --progress --stats=errors-only",
    "docs": "node scripts/build-docs.mjs",
    "docs:api": "jsdoc -c jsdoc.config.json",
    "docs:api:watch": "nodemon --watch src --exec 'npm run docs:api'",
    "docs:validate": "eslint src/**/*.mjs --no-eslintrc --parser-options=ecmaVersion:2023,sourceType:module --rule 'valid-jsdoc: [error, {requireReturn: false}]'",
    "docs:coverage": "node scripts/check-jsdoc-coverage.mjs",
    "docs:all": "npm run docs && npm run docs:api",
    "task": "node scripts/task.mjs",
    "sync:nft": "node scripts/task.mjs sync:collection",
    "update:models": "node scripts/task.mjs update:models",
    "backfill:agent-ids": "node scripts/task.mjs backfill:agent-ids",
    "migrate:agent-blocks": "node scripts/task.mjs migrate:agent-blocks",
    "migrate:agent-events": "node scripts/task.mjs migrate:agent-events",
    "test:agent-events": "node scripts/testAgentEvents.mjs",
    "lint": "npx eslint .",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "analyze": "npx webpack --mode production --profile --json > webpack-stats.json",
    "smoke:ai": "node scripts/smoke-ai.mjs",
    "test:global-x": "node scripts/test-global-x-posting.mjs",
    "check:version": "node scripts/check-version-bump.mjs",
    "prepare": "node scripts/install-git-hooks.mjs",
    "deploy:setup-db": "node scripts/create-indexes.js",
    "deploy:verify": "node scripts/verify-phase2-deployment.js",
    "deploy:prepare": "npm run lint && npm run build:js && npm run deploy:setup-db && npm run deploy:verify",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "discord",
    "ai",
    "avatar",
    "rpg"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cenetex/cosyworld.git"
  },
  "author": "Jon Beckwith",
  "license": "MIT",
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.38.4",
    "@google/genai": "^0.9.0",
    "@google/generative-ai": "^0.22.0",
    "@modelcontextprotocol/sdk": "^1.9.0",
    "@modelcontextprotocol/server-memory": "^0.6.2",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "arweave": "^1.15.5",
    "autoprefixer": "^10.4.21",
    "awilix": "^12.0.5",
    "axios": "^1.8.4",
    "better-sqlite3": "^11.10.0",
    "bs58": "^6.0.0",
    "cookie-parser": "^1.4.6",
    "copy-webpack-plugin": "^13.0.0",
    "cors": "^2.8.5",
    "csv-stringify": "^6.5.2",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "ethers": "^6.15.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "fuse.js": "^7.0.0",
    "globby": "^14.1.0",
    "helius-sdk": "^2.0.2",
    "js-sha3": "^0.9.3",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.11.0",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "ollama": "^0.5.9",
    "openai": "^4.73.0",
    "postcss": "^8.4.49",
    "replicate": "^1.0.1",
    "sharp": "^0.33.5",
    "string-similarity": "^4.0.4",
    "tailwindcss": "^3.4.17",
    "telegraf": "^4.16.3",
    "tweetnacl": "^1.0.3",
    "twitter-api-v2": "^1.18.2",
    "uuid": "^11.1.0",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@babel/preset-env": "^7.26.9",
    "@babel/runtime": "^7.27.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "babel-loader": "^10.0.0",
    "c8": "^10.1.3",
    "core-js": "^3.38.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "docdash": "^2.0.2",
    "eslint": "^9.24.0",
    "jsdoc": "^4.0.4",
    "markdown-it": "^14.1.0",
    "mini-css-extract-plugin": "^2.9.2",
    "nodemon": "^3.0.3",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.10",
    "sinon": "^19.0.5",
    "style-loader": "^3.3.4",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  }
}
